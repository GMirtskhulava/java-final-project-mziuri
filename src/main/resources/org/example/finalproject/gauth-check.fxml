<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="675.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finalproject.controllers.GAuthCheckController">
    <children>

        <VBox alignment="CENTER" prefWidth="350.0" styleClass="left-pane" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="brand-title" text="SocNet" />
                <Label styleClass="brand-subtitle" text="Connect with World" textAlignment="CENTER">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox alignment="CENTER_LEFT" prefWidth="500.0" styleClass="right-pane" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
            </padding>
            <children>
            <Label styleClass="form-title" text="Google Authenticator">
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
                <Label styleClass="form-subtitle" text="Enter code from Google Authenticator App">
                    <VBox.margin>
                        <Insets bottom="30.0" />
                    </VBox.margin>
                </Label>

                <VBox spacing="15.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <TextField fx:id="authCodeField" promptText="Enter code" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT">
                    <VBox.margin>
                        <Insets top="8.0" />
                    </VBox.margin>
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleLostAccessbutton" styleClass="btn-secondary" text="Lost access?" />
                    </children>
                </HBox>

                <Label fx:id="errorLabel" minHeight="18.0" styleClass="label-error" textFill="RED" wrapText="true">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                </Label>

                <Button fx:id="loginButton" defaultButton="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLoginButton" styleClass="btn-primary" text="Sign In">
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Button>

                <HBox alignment="CENTER" spacing="5.0">
                    <VBox.margin>
                        <Insets top="30.0" />
                    </VBox.margin>
                    <children>
                        <Label styleClass="label-light" text="Back to" />
                        <Button fx:id="navigateBackButton" mnemonicParsing="false" onAction="#navigateToBack" styleClass="btn-secondary" text="Sign In" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>
