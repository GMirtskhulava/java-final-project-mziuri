<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="675.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finalproject.controllers.PongController">
    <children>
        <AnchorPane prefHeight="50.0" prefWidth="1200.0">
            <children>
                <Button layoutX="23.0" layoutY="13.0" mnemonicParsing="false" onAction="#handleBackButton" text="Back"/>
                <Label fx:id="scoreBLabel" alignment="CENTER" layoutX="567.0" layoutY="7.0" prefHeight="36.0" prefWidth="30.0" text="99">
                    <font>
                        <Font size="25.0"/>
                    </font>
                </Label>
                <Label layoutX="598.0" layoutY="9.0" text=":">
                    <font>
                        <Font size="22.0"/>
                    </font>
                </Label>
                <Label fx:id="scoreRLabel" alignment="CENTER" layoutX="603.0" layoutY="7.0" prefHeight="36.0" prefWidth="30.0" text="99">
                    <font>
                        <Font size="25.0"/>
                    </font>
                </Label>
                <Line endX="20.0" layoutX="572.0" layoutY="40.0" stroke="#0f00ff" strokeWidth="2.0" AnchorPane.bottomAnchor="9.0" AnchorPane.rightAnchor="607.0"/>
                <Line endX="20.0" layoutX="608.0" layoutY="40.0" stroke="RED" strokeWidth="2.0"/>
            </children>
        </AnchorPane>
        <AnchorPane fx:id="paddleSquarePane" prefHeight="625.0" prefWidth="1200.0" styleClass="pong-game-square" stylesheets="@styles.css">
            <children>
                <Rectangle fx:id="paddleB" arcHeight="5.0" arcWidth="5.0" fill="DODGERBLUE" height="80.0" layoutX="30.0" layoutY="276.0" stroke="BLACK" strokeType="INSIDE" width="15.0"/>
                <Rectangle fx:id="paddleR" arcHeight="5.0" arcWidth="5.0" fill="#ff1f1f" height="80.0" layoutX="1155.0" layoutY="275.0" stroke="BLACK" strokeType="INSIDE" width="15.0"/>

                <Circle fx:id="ball" fill="#5fff1f" layoutX="600.0" layoutY="313.0" radius="25.0" stroke="BLACK" strokeType="INSIDE"/>
                <Button fx:id="gameStartButton" layoutX="499.0" layoutY="87.0" mnemonicParsing="false" onAction="#handleGameStart" prefHeight="100.0" prefWidth="203.0" styleClass="pong-game-start-btn" text="Click here to start">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Button>
                <Label fx:id="hintTitleLabel" alignment="TOP_CENTER" layoutX="576.0" layoutY="482.0" prefHeight="17.0" prefWidth="50.0" text="Hints:" textFill="WHITE"/>
                <Label fx:id="hintBLabel" alignment="TOP_LEFT" layoutX="484.0" layoutY="503.0" prefHeight="17.0" prefWidth="234.0" text="Blue paddle movement: W / S" textFill="#d0ccff" wrapText="true"/>
                <Label fx:id="hintRLabel" alignment="TOP_LEFT" layoutX="484.0" layoutY="520.0" prefHeight="17.0" prefWidth="234.0" text="Red paddle movement: Arrow Up / Down" textFill="#ffa8a8" wrapText="true"/>
                <Label fx:id="hintScoreLabel" alignment="TOP_LEFT" layoutX="484.0" layoutY="537.0" prefHeight="17.0" prefWidth="234.0" text="Every 3 points, the difficulty increases." textFill="#fffda8" wrapText="true"/>
            </children>
        </AnchorPane>
    </children>
</VBox>