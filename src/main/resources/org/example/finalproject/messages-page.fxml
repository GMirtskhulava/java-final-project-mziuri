<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="675.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finalproject.controllers.MessagesController">
    <top><HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="navbar"><children><Label styleClass="navbar-logo" text="SocNet" /><HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS"><children><TextField fx:id="searchField" onAction="#showSearch" prefWidth="250.0" promptText="Search SocNet..." styleClass="search-bar" /><HBox alignment="CENTER" spacing="10.0"><children><Circle fill="#2ec4b6" radius="18.0" stroke="TRANSPARENT" /><Label fx:id="topUsernameLabel" onMouseClicked="#openMyProfile" styleClass="navbar-username" text="User Account" /></children><HBox.margin><Insets left="10.0" /></HBox.margin></HBox></children></HBox></children><padding><Insets left="25.0" right="25.0" /></padding></HBox></top>
    <left>
        <VBox prefWidth="200.0" spacing="5.0" styleClass="sidebar">
            <children>
                <Button fx:id="navFeedBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showFeed" styleClass="sidebar-btn" text="Feed" />
                <Button fx:id="navProfileBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showProfile" styleClass="sidebar-btn" text="Profile" />
                <Button fx:id="navMessagesBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showMessages" text="Messages"><styleClass><String fx:value="sidebar-btn" /><String fx:value="active-nav" /></styleClass></Button>
                <Button fx:id="navFriendsBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showFriends" styleClass="sidebar-btn" text="Friends" />
                <Button fx:id="navGamesBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showGames" styleClass="sidebar-btn" text="Games" />
                <Button fx:id="navSettingsBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showSettings" styleClass="sidebar-btn" text="Settings" />
                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS"><children><Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogOutButton" styleClass="btn-logout" text="Log Out" /></children><padding><Insets bottom="20.0" /></padding></VBox>
            </children>
            <padding><Insets left="15.0" right="15.0" top="25.0" /></padding>
        </VBox>
    </left>
    <center>
        <HBox minHeight="550.0" styleClass="messenger-shell">
            <children>
                <VBox prefWidth="225.0" spacing="10.0" styleClass="chat-sidebar">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #1b4d3e; -fx-font-size: 16px;" text="Chats" />
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <VBox fx:id="userListContainer" spacing="5.0" />
                            </content>
                        </ScrollPane>
                    </children>
                    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="15.0" /></padding>
                </VBox>
                <BorderPane HBox.hgrow="ALWAYS">
                    <top><HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="conversation-header"><children><Circle fill="#1b4d3e" radius="18.0" stroke="TRANSPARENT" /><VBox HBox.hgrow="ALWAYS"><children><Label fx:id="conversationNameLabel" style="-fx-font-weight: bold; -fx-text-fill: #1b4d3e;" text="Select chat" /><Label fx:id="conversationStatusLabel" styleClass="status-online" text="Choose a friend to start messaging" /></children></VBox><CheckBox fx:id="pinCheckBox" onAction="#toggleChatPin" text="Pin chat" /></children><padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding></HBox></top>
                    <center><ScrollPane fx:id="messagesScrollPane" fitToWidth="true" styleClass="conversation-area"><content><VBox fx:id="messagesContainer" spacing="10.0"><padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding></VBox></content></ScrollPane></center>
                    <bottom><HBox alignment="CENTER" spacing="10.0" styleClass="message-input-bar"><children><TextField fx:id="messageField" onAction="#handleSendMessage" promptText="Type a message..." styleClass="text-field" HBox.hgrow="ALWAYS" /><Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSendMessage" style="-fx-padding: 8 20 8 20;" styleClass="btn-primary" text="Send" /></children><padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding></HBox></bottom>
                </BorderPane>
            </children>
            <BorderPane.margin><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></BorderPane.margin>
        </HBox>
    </center>
</BorderPane>
