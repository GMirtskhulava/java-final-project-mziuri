<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="675.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finalproject.controllers.FriendsController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="navbar"><children><Label styleClass="navbar-logo" text="SocNet" /><HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS"><children><TextField fx:id="searchField" onAction="#showSearch" prefWidth="250.0" promptText="Search SocNet..." styleClass="search-bar" /><HBox alignment="CENTER" spacing="10.0"><children><Circle fill="#2ec4b6" radius="18.0" stroke="TRANSPARENT" /><Label fx:id="topUsernameLabel" onMouseClicked="#openMyProfile" styleClass="navbar-username" text="User Account" /></children><HBox.margin><Insets left="10.0" /></HBox.margin></HBox></children></HBox></children><padding><Insets left="25.0" right="25.0" /></padding></HBox>
    </top>
    <left>
        <VBox prefWidth="220.0" spacing="5.0" styleClass="sidebar">
            <children>
                <Button fx:id="navFeedBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showFeed" styleClass="sidebar-btn" text="Feed" />
                <Button fx:id="navProfileBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showProfile" styleClass="sidebar-btn" text="Profile" />
                <Button fx:id="navMessagesBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showMessages" styleClass="sidebar-btn" text="Messages" />
                <Button fx:id="navFriendsBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showFriends" text="Friends"><styleClass><String fx:value="sidebar-btn" /><String fx:value="active-nav" /></styleClass></Button>
                <Button fx:id="navGamesBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showGames" styleClass="sidebar-btn" text="Games" />
                <Button fx:id="navSettingsBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showSettings" styleClass="sidebar-btn" text="Settings" />
                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS"><children><Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogOutButton" styleClass="btn-logout" text="Log Out" /></children><padding><Insets bottom="20.0" /></padding></VBox>
            </children>
            <padding><Insets left="15.0" right="15.0" top="25.0" /></padding>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="feed-scrollpane" vbarPolicy="AS_NEEDED"><content><VBox spacing="20.0" styleClass="main-content-container"><children>
            <Label fx:id="friendsTitleLabel" styleClass="form-title" text="Friends" />
            <VBox fx:id="friendsContainer" spacing="10.0">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="friend-row"><children><Circle fill="#a3e2c9" radius="22.0" stroke="TRANSPARENT" /><VBox HBox.hgrow="ALWAYS"><children><Label style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1b4d3e;" text="Elena Rostova" /><Label styleClass="status-online" text="Active Now" /></children></VBox><Button mnemonicParsing="false" styleClass="btn-secondary" text="рџ’¬ Message" /><Button mnemonicParsing="false" style="-fx-padding: 6 12 6 12; -fx-font-size: 12px;" styleClass="btn-logout" text="Unfriend" /></children><padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding></HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="friend-row"><children><Circle fill="#2ec4b6" radius="22.0" stroke="TRANSPARENT" /><VBox HBox.hgrow="ALWAYS"><children><Label style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1b4d3e;" text="Nika Beridze" /><Label style="-fx-font-size: 12px; -fx-text-fill: #888888;" text="Last seen recently" /></children></VBox><Button mnemonicParsing="false" styleClass="btn-secondary" text="рџ’¬ Message" /><Button mnemonicParsing="false" style="-fx-padding: 6 12 6 12; -fx-font-size: 12px;" styleClass="btn-logout" text="Unfriend" /></children><padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding></HBox>
                </children>
            </VBox>
        </children><padding><Insets bottom="30.0" left="25.0" right="25.0" top="25.0" /></padding></VBox></content></ScrollPane>
    </center>
</BorderPane>

