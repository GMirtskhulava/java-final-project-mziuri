<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="675.0" prefWidth="1200.0"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.finalproject.controllers.DeveloperAppController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="navbar">
            <children>
                <Label styleClass="navbar-logo" text="Developers SocNet"/>

                <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Circle fill="#2ec4b6" radius="18.0" stroke="TRANSPARENT"/>
                                <Label fx:id="topUsernameLabel"
                                       onMouseClicked="#openMyProfile"
                                       styleClass="navbar-username"
                                       text="User Account"/>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets left="25.0" right="25.0"/>
            </padding>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="5.0" styleClass="sidebar">
            <children>
                <Button alignment="BASELINE_LEFT"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#showProfile"
                        styleClass="sidebar-btn"
                        text="Profile"/>

                <Button alignment="BASELINE_LEFT"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#showDashboard"
                        text="Dashboard">
                    <styleClass>
                        <String fx:value="sidebar-btn"/>
                    </styleClass>
                </Button>

                <Button alignment="BASELINE_LEFT"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        text="Developer App">
                    <styleClass>
                        <String fx:value="sidebar-btn"/>
                        <String fx:value="active-nav"/>
                    </styleClass>
                </Button>

                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
                    <children>
                        <Button maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                onAction="#handleLogOutButton"
                                styleClass="btn-logout"
                                text="Log Out"/>
                    </children>
                    <padding>
                        <Insets bottom="20.0"/>
                    </padding>
                </VBox>
            </children>
            <padding>
                <Insets left="15.0" right="15.0" top="25.0"/>
            </padding>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    styleClass="feed-scrollpane"
                    vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="20.0" styleClass="main-content-container">
                    <children>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label styleClass="form-title" text="Developer App"/>
                            </children>
                        </HBox>

                        <VBox spacing="18.0" styleClass="card">
                            <children>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="developer-dashboard-title" text="App information"/>
                                        <Label fx:id="messageLabel"
                                               styleClass="developer-dashboard-message"
                                               text="Create, save, and publish your SocNet Game (using javaFX)!"/>
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="section-title" text="App name"/>
                                        <TextField fx:id="appNameField"
                                                   promptText="Enter app name"/>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="section-title" text="Status:"/>
                                        <Label fx:id="statusLabel"
                                               styleClass="status-draft"
                                               text="Draft"/>
                                    </children>
                                </HBox>

                                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="section-title" text="Java code"/>
                                        <TextArea fx:id="javaCodeArea"
                                                  prefHeight="330.0"
                                                  promptText="Enter your Java code here..."
                                                  wrapText="false"
                                                  styleClass="code-area"/>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <children>
                                        <Button mnemonicParsing="false"
                                                onAction="#handleSaveButton"
                                                prefWidth="130.0"
                                                styleClass="btn-primary"
                                                text="Save"/>

                                        <Button mnemonicParsing="false"
                                                onAction="#handlePublishButton"
                                                prefWidth="130.0"
                                                styleClass="btn-secondary-bordered"
                                                text="Publish"/>
                                    </children>
                                </HBox>

                            </children>
                            <padding>
                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0"/>
                            </padding>
                        </VBox>

                    </children>
                    <padding>
                        <Insets bottom="30.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>