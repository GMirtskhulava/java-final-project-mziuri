<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="675.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finalproject.DevelopersController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="navbar">
            <children>
                <Label styleClass="navbar-logo" text="Developers SocNet" />
                <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Circle fill="#2ec4b6" radius="18.0" stroke="TRANSPARENT" />
                                <Label fx:id="topUsernameLabel" onMouseClicked="#openMyProfile" styleClass="navbar-username" text="User Account" />
                            </children>
                            <HBox.margin><Insets left="10.0" /></HBox.margin>
                        </HBox>
                    </children>
                </HBox>
            </children>
            <padding><Insets left="25.0" right="25.0" /></padding>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="5.0" styleClass="sidebar">
            <children>
                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openMyProfile" styleClass="sidebar-btn" text="Profile" />
                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboard" text="Dashboard">
               <styleClass>
                  <String fx:value="sidebar-btn" />
                  <String fx:value="active-nav" />
               </styleClass></Button>
                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
                    <children><Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogOutButton" styleClass="btn-logout" text="Log Out" /></children>
                    <padding><Insets bottom="20.0" /></padding>
                </VBox>
            </children>
            <padding><Insets left="15.0" right="15.0" top="25.0" /></padding>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="feed-scrollpane" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="20.0" styleClass="main-content-container">
                    <children>
                  <HBox prefHeight="38.0" prefWidth="915.0">
                     <children>
                              <Label prefHeight="32.0" prefWidth="145.0" styleClass="form-title" text="Your apps:" />
                     </children>
                  </HBox>
                        <VBox fx:id="appListNode" prefHeight="512.0" prefWidth="915.0" spacing="15.0" styleClass="card">
                            <children>
                        <VBox prefHeight="45.0" prefWidth="873.0">
                           <children>
                                      <Label styleClass="developer-dashboard-title" text="Choose app" />
                              <Label fx:id="messageLabel" styleClass="developer-dashboard-message" text="">
                                 <VBox.margin>
                                    <Insets top="4.0" />
                                 </VBox.margin>
                              </Label>
                           </children>
                        </VBox>
                                <Button mnemonicParsing="false" onAction="#handleCreateNewGameButton" prefHeight="150.0" prefWidth="240.0" styleClass="game-choice-btn" text="Create new" />
                            </children>
                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        </VBox>
                    </children>
                    <padding><Insets bottom="30.0" left="25.0" right="25.0" top="25.0" /></padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
